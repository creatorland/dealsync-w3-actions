{
  "name": "@dealsync/w3-actions",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "test": "NODE_ENV=test npx vitest run",
    "test:watch": "NODE_ENV=test npx vitest",
    "check-dist": "npm run build && git diff --exit-code -- '*/dist/'",
    "lint": "cd .. && npm run lint",
    "format": "cd .. && npm run format"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@rollup/plugin-wasm": "^6.2.2",
    "sxt-nodejs-sdk": "^2.1.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "rollup": "^4.28.0",
    "rollup-plugin-string": "^3.0.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=22"
  }
}
